{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "backend/main.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/admin/:path*",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }],
      "destination": "/admin/index.html"
    },
    {
      "source": "/((?!auth(?:/|$)|profile(?:/|$)|chat$|tts$|offers$|public/offers|public/promotions|userdata$|webhooks(?:/|$)|admin/(?:health|me|usage|upload|offers|promotions|regions|invite_codes|profiles|users|user_data|activity_log|invite_tester)(?:/|$)|static/).*)",
      "destination": "/index.html"
    }
  ]
}
