# Copy to .env and fill in values
ADMIN_SECRET=your-local-admin-password

SUPABASE_URL=
# service_role secret only — NOT anon/publishable (Dashboard → Settings → API)
SUPABASE_SERVICE_KEY=

ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# Resend — https://resend.com/api-keys (tester invites without Supabase, password reset)
RESEND_API_KEY=
LS_API_KEY=

# Optional — redirect after Supabase invite/confirm links
# APP_URL=https://app.vdarpp.com

# Optional — default: offer-news
# OFFER_NEWS_TABLE=offer-news
