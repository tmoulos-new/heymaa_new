# Copy to .env and fill in values

SUPABASE_URL=
# service_role secret only — NOT anon/publishable (Dashboard → Settings → API)
SUPABASE_SERVICE_KEY=

ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# Resend — https://resend.com/api-keys (tester invites without Supabase, password reset)
RESEND_API_KEY=
LS_API_KEY=

# Optional — first admin when no admin exists yet (must match a registered user email)
# BOOTSTRAP_ADMIN_EMAIL=you@example.com

# Optional — redirect after Supabase invite/confirm links
# APP_URL=https://heymaa.vercel.app
# RESEND_FROM=HeyMaa <hello@vdarpp.com>

# Optional — default: offers
# OFFERS_TABLE=offers
